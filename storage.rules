rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isActive() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    match /{allPaths=**} {
      allow read, write: if isActive() && role() == 'Administrator';
    }
  }
}
